generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id            String   @id @default(uuid()) @db.Uuid
  full_name     String   @db.VarChar(100)
  email         String   @unique @db.VarChar(100)
  phone         String   @db.VarChar(15)
  password_hash String   @db.VarChar(255)
  created_at    DateTime @default(now())
  meters        Meter[]
}

model Tariff {
  band         String   @id @db.VarChar(10) // e.g. "A", "B", "C"
  rate_per_kwh Decimal  @db.Decimal(10, 2)
  updated_at   DateTime @updatedAt
  meters       Meter[]
}

model Meter {
  id            String        @id @default(uuid()) @db.Uuid
  customer_id   String        @db.Uuid
  meter_number  String        @unique @db.VarChar(20)
  tariff_band   String        @db.VarChar(10)
  created_at    DateTime      @default(now())
  units_balance Decimal       @default(0.00) @db.Decimal(10, 2) // simulated credit balance
  customer      Customer      @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  tariff        Tariff        @relation(fields: [tariff_band], references: [band])
  transactions  Transaction[]
}

model Transaction {
  id             String      @id @default(uuid()) @db.Uuid
  meter_id       String      @db.Uuid
  amount         Decimal     @db.Decimal(10, 2)
  payment_ref    String      @unique @db.VarChar(50)
  payment_status String      @db.VarChar(20) // pending | successful | failed
  created_at     DateTime    @default(now())
  meter          Meter       @relation(fields: [meter_id], references: [id], onDelete: Cascade)
  token          Token?
}

model Token {
  id             String      @id @default(uuid()) @db.Uuid
  transaction_id String      @unique @db.Uuid
  token_value    String      @db.VarChar(24) // Formatted as XXXX-XXXX-XXXX-XXXX-XXXX
  units          Decimal     @db.Decimal(10, 2)
  is_used        Boolean     @default(false)
  used_at        DateTime?
  created_at     DateTime    @default(now())
  transaction    Transaction @relation(fields: [transaction_id], references: [id], onDelete: Cascade)
}

model Admin {
  id            String   @id @default(uuid()) @db.Uuid
  full_name     String   @db.VarChar(100)
  email         String   @unique @db.VarChar(100)
  password_hash String   @db.VarChar(255)
  role          String   @db.VarChar(20) // superadmin | staff
  created_at    DateTime @default(now())
}
